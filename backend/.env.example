# Supabase: Dashboard → Project Settings → API
# Database: Dashboard → Project Settings → Database → Connection string

# --- Supabase (Auth + API) ---

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres (Alembic + direct DB access) ---

# Use the DIRECT connection (host: db.<ref>.supabase.co).
# Do NOT use the transaction pooler URL (pooler.supabase.com) — migrations require a session connection.
# URL-encode special characters in the password.
DATABASE_URL=

# --- OpenAI (needed once the LLM / embedding layer is wired up) ---

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4.1-mini
# Multi-year / multi-filing questions can need many search + read tool calls.
AGENT_MAX_TOOL_CALLS=20

# --- Server ---

# Comma-separated browser origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173
